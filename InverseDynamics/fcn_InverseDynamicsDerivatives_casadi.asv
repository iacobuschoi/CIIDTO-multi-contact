%     'Vars', {gc_m, gc_n, gc_p});

% f = Function('getUdgcm',{gc_m, gc_n, gc_p},{u_dgc_m});
% opts = struct('main', true,...
%               'mex', true);
% f.generate('getUdgcm.c',opts);
