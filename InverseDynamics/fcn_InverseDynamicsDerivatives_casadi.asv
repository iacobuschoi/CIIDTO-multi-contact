% matlabFunction( ...
%     u_dgc_n, ...
%     'File', 'getUdgcn', ...
%     'Outputs', {'u_dgc_n'}, ...
%     'Vars', {gc_m, gc_n, gc_p});
% matlabFunction( ...
%     u_dgc_p, ...
%     'File', 'getUdgcp', ...
%     'Outputs', {'u_dgc_p'}, ...
%     'Vars', {gc_m, gc_n, gc_p});
% matlabFunction( ...
%     gv_n_dgc_n, ...
%     'File', 'getGvndgcn', ...
%     'Outputs', {'gv_n_dgc_n'}, ...
%     'Vars', {gc_m, gc_n, gc_p});
% matlabFunction( ...
%     gv_n_dgc_m, ...
%     'File', 'getGvndgcm', ...
%     'Outputs', {'gv_n_dgc_m'}, ...
%     'Vars', {gc_m, gc_n, gc_p});
% 
% disp('Generated getInverseDynamicsDerivatives.m');

%% -------- local function used by symbolic construction ----------
function Fi = localPairForce(pi,pj,vi,vj,Ri,Rj,mu,v_d,v_s,c_from_phi,d_from_vr)
    % gap phi = distance - (Ri+Rj)
    dp = pi - pj;
    dist = sqrt(dp.'*dp + 1e-12); % avoid singularity
    n = dp / dist;                % normal (from j->i)
    t = [-n(2); n(1)];            % tangent

    vrel = vi - vj;
    vt = t.'*vrel;
    vn = n.'*vrel;

    phi = dist - (Ri + Rj);

    c  = c_from_phi(phi);
    vr = vn / v_d;
    d  = d_from_vr(vr);

    % contact-frame forces (same structure as your model)
    ft = -mu * vt * c * d / sqrt(v_s^2 + vt^2);
    fn =  c * d;

    % world force on i
    Fi = t*ft + n*fn;
end